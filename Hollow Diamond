SOURCE CODE:
#include <iostream>
using namespace std;

int main()
{
    int n;
    cin>>n;
    
    for(int i=0;i<n;i++)
    {
        for(int k=0;k<n-i-1;k++)
            cout<<" ";
        for(int j=0;j<=i;j++)
        {
            if(j==0 || j==i)
                cout<<"* ";
            else
                cout<<"  ";
        }
            
        cout<<endl;
    }
    for(int i=n-2;i>=0;i--)
    {
        for(int k=0;k<n-i-1;k++)
            cout<<" ";
        for(int j=0;j<=i;j++)
        {
            if(j==0 || j==i)
                cout<<"* ";
            else
                cout<<"  ";
        }
            
        cout<<endl;
    }
}

