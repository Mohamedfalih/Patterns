           BUTTERFLT PATTERN

SOURCE CODE:
#include <iostream>
using namespace std;

int main()
{
    int n;
    cin>>n;
    //top half
    for(int i=0;i<n;i++)
    {
        for(int j=0;j<=i;j++)
        {
            cout<<"*";//first triangle
        }
        for(int k=0;k<2*(n-i-1);k++)
        {
            cout<<" ";//center space
        }
        for(int j=0;j<=i;j++)
        {
            cout<<"*";//last triangle
        }
        cout<<endl;
    }
    //bottom half
    for(int i=n-2;i>=0;i--)
    {
        for(int j=0;j<=i;j++)
        {
            cout<<"*";//first triangle
        }
        for(int k=0;k<2*(n-i-1);k++)
        {
            cout<<" ";//center space
        }
        for(int j=0;j<=i;j++)
        {
            cout<<"*";//last triangle
        }
        cout<<endl;
    }
}

